# =============================================================================
# Makefile — SAM lib
# =============================================================================

CXX     := g++
AR      := ar
ARFLAGS := rcs

# -----------------------------------------------------------------------------
# Build mode
# -----------------------------------------------------------------------------
BUILD ?= debug

ifeq ($(BUILD),release)
    OPT_FLAGS := -O3 -DNDEBUG
else
    OPT_FLAGS := -O0 -g
endif

# -----------------------------------------------------------------------------
# ITPP
# -----------------------------------------------------------------------------
ITPP_CFLAGS := $(shell pkg-config --cflags itpp)

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
INC_DIR := include
SRC_DIR := src
OUT_DIR := bin/sam

CXXFLAGS := -std=c++17 -Wall -Wextra -Wpedantic \
            $(OPT_FLAGS)                          \
            -I$(INC_DIR)                          \
            $(ITPP_CFLAGS)

# -----------------------------------------------------------------------------
# Sources
# -----------------------------------------------------------------------------
SRCS := $(shell find $(SRC_DIR) -name '*.cpp')
OBJS := $(patsubst $(SRC_DIR)/%.cpp, $(OUT_DIR)/obj/%.o, $(SRCS))
LIB  := $(OUT_DIR)/libsam.a

# -----------------------------------------------------------------------------
# Targets
# -----------------------------------------------------------------------------
.PHONY: all clean info

all: $(LIB)

$(LIB): $(OBJS)
	@mkdir -p $(dir $@)
	$(AR) $(ARFLAGS) $@ $^
	@echo "[AR]  $@"

$(OUT_DIR)/obj/%.o: $(SRC_DIR)/%.cpp
	@mkdir -p $(dir $@)
	$(CXX) $(CXXFLAGS) -c $< -o $@
	@echo "[CXX] $<"

clean:
	rm -rf bin/
	@echo "[CLEAN] done"

info:
	@echo "BUILD = $(BUILD)"
	@echo "LIB   = $(LIB)"
	@echo "SRCS  = $(SRCS)"